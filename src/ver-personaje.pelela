<pelela view-model="VerPersonaje">
  <div class="titulo">
    <img bind-src="personaje.imagen" />
    <h2 bind-content="personaje.nombre"></h2>
  </div>
  <hr/>
  <div class="personaje-data">
    <div bind-content="personaje.especie" class="title"></div>
    <div bind-content="personaje.estado" class="state"></div>
    <div bind-content="personaje.genero"></div>
  </div>
  <button data-testid="volver" class="botonera" click="volver">Volver</button>
</pelela>
